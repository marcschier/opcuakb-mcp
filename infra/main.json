{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "languageVersion": "2.0",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.36.1.42791",
      "templateHash": "14337601578914761692"
    }
  },
  "parameters": {
    "prefix": {
      "type": "string",
      "defaultValue": "opcua-kb",
      "minLength": 3,
      "metadata": {
        "description": "Prefix used to derive all resource names"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for all resources"
      }
    },
    "gptModelVersion": {
      "type": "string",
      "defaultValue": "2024-11-20",
      "metadata": {
        "description": "GPT-4o model version"
      }
    },
    "pipelineImage": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Container image for the pipeline job (empty = placeholder)"
      }
    },
    "cronSchedule": {
      "type": "string",
      "defaultValue": "0 2 * * 0",
      "metadata": {
        "description": "Cron schedule for the pipeline job"
      }
    },
    "cloudLibUsername": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "Optional: UA-CloudLibrary username (enables CloudLib integration)"
      }
    },
    "cloudLibPassword": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "Optional: UA-CloudLibrary password"
      }
    },
    "lockdownStorage": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "When true, set storage publicNetworkAccess=Disabled and require VNet/private-endpoint access only. Toggle on after the first pipeline run has validated the deployment end-to-end."
      }
    }
  },
  "variables": {
    "searchName": "[format('{0}-search', parameters('prefix'))]",
    "foundryName": "[format('{0}-foundry', parameters('prefix'))]",
    "storageName": "[take(replace(format('{0}storage', parameters('prefix')), '-', ''), 24)]",
    "docaiName": "[format('{0}-docai', parameters('prefix'))]",
    "acrName": "[replace(format('{0}registry', parameters('prefix')), '-', '')]",
    "envName": "[format('{0}-env', parameters('prefix'))]",
    "jobName": "[format('{0}-pipeline-job', parameters('prefix'))]",
    "mcpAppName": "[format('{0}-mcp-server', parameters('prefix'))]",
    "logAnalyticsName": "[format('{0}-logs', parameters('prefix'))]",
    "workbookName": "[guid(resourceGroup().id, 'opcua-pipeline-dashboard')]",
    "vnetName": "[format('{0}-vnet', parameters('prefix'))]",
    "vnetCidr": "10.20.0.0/24",
    "appsSubnetName": "apps-subnet",
    "appsSubnetCidr": "10.20.0.0/26",
    "peSubnetName": "pe-subnet",
    "peSubnetCidr": "10.20.0.64/28",
    "containerImage": "[if(empty(parameters('pipelineImage')), 'mcr.microsoft.com/dotnet/runtime:9.0', parameters('pipelineImage'))]",
    "cognitiveServicesOpenAIUserRole": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '5e0bd9bd-7b93-4f28-af87-19fc36ad61bd')]",
    "storageBlobDataContributorRole": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', 'ba92f5b4-2d11-453d-a403-e96b0029c9fe')]",
    "acrPullRole": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '7f951dda-4ed3-4680-a7ca-43fe172d538d')]",
    "workbookContent": "{\"version\":\"Notebook/1.0\",\"items\":[{\"type\":1,\"content\":{\"json\":\"# OPC UA Knowledge Base Pipeline Dashboard\\n\\nMonitors crawl + index pipeline for reference.opcfoundation.org\"},\"name\":\"header\"},{\"type\":3,\"content\":{\"version\":\"KqlItem/1.0\",\"query\":\"ContainerAppConsoleLogs_CL\\n| where ContainerGroupName_s startswith \\\"opcua-pipeline-job\\\"\\n| where Log_s has \\\"[PIPELINE]\\\"\\n| parse Log_s with * \\\"Phase=\\\" Phase:string \\\" Status=\\\" Status:string \\\" \\\" *\\n| project TimeGenerated, Phase, Status\\n| order by TimeGenerated desc\\n| take 20\",\"size\":1,\"title\":\"Recent Pipeline Events\",\"timeContext\":{\"durationMs\":604800000},\"queryType\":0,\"resourceType\":\"microsoft.operationalinsights/workspaces\"},\"name\":\"pipeline-events\"},{\"type\":3,\"content\":{\"version\":\"KqlItem/1.0\",\"query\":\"ContainerAppConsoleLogs_CL\\n| where ContainerGroupName_s startswith \\\"opcua-pipeline-job\\\"\\n| where Log_s has \\\"[CRAWL]\\\" and Log_s has \\\"Downloaded=\\\"\\n| parse Log_s with * \\\"Downloaded=\\\" Downloaded:long \\\" Skipped=\\\" Skipped:long \\\" Errors=\\\" Errors:long \\\" Queued=\\\" Queued:long\\n| project TimeGenerated, Downloaded, Skipped, Errors, Queued\\n| order by TimeGenerated asc\",\"size\":0,\"title\":\"Crawl Progress Over Time\",\"timeContext\":{\"durationMs\":86400000},\"queryType\":0,\"resourceType\":\"microsoft.operationalinsights/workspaces\",\"visualization\":\"linechart\",\"chartSettings\":{\"yAxis\":[\"Downloaded\",\"Queued\",\"Errors\"]}},\"name\":\"crawl-progress\"},{\"type\":3,\"content\":{\"version\":\"KqlItem/1.0\",\"query\":\"ContainerAppConsoleLogs_CL\\n| where ContainerGroupName_s startswith \\\"opcua-pipeline-job\\\"\\n| where Log_s has \\\"[CRAWL]\\\" and Log_s has \\\"Downloaded=\\\"\\n| parse Log_s with * \\\"Downloaded=\\\" Downloaded:long \\\" Skipped=\\\" Skipped:long \\\" Errors=\\\" Errors:long *\\n| summarize MaxDownloaded=max(Downloaded), MaxSkipped=max(Skipped), TotalErrors=max(Errors) by bin(TimeGenerated, 1h)\\n| order by TimeGenerated desc\\n| take 1\",\"size\":4,\"title\":\"Latest Crawl Stats\",\"timeContext\":{\"durationMs\":86400000},\"queryType\":0,\"resourceType\":\"microsoft.operationalinsights/workspaces\",\"visualization\":\"tiles\",\"tileSettings\":{\"showBorder\":true}},\"name\":\"crawl-stats\"},{\"type\":3,\"content\":{\"version\":\"KqlItem/1.0\",\"query\":\"ContainerAppConsoleLogs_CL\\n| where ContainerGroupName_s startswith \\\"opcua-pipeline-job\\\"\\n| where Log_s has \\\"[INDEX]\\\" and Log_s has \\\"Phase=\\\"\\n| parse Log_s with * \\\"Phase=\\\" Phase:string \\\" \\\" *\\n| extend Embedded = extract(\\\"Embedded=([0-9]+)\\\", 1, Log_s)\\n| extend Uploaded = extract(\\\"Uploaded=([0-9]+)\\\", 1, Log_s)\\n| extend Chunks = extract(\\\"Chunks=([0-9]+)\\\", 1, Log_s)\\n| extend Parsed = extract(\\\"Parsed=([0-9]+)\\\", 1, Log_s)\\n| project TimeGenerated, Phase, Parsed, Chunks, Embedded, Uploaded\\n| order by TimeGenerated asc\",\"size\":0,\"title\":\"Index Progress Over Time\",\"timeContext\":{\"durationMs\":86400000},\"queryType\":0,\"resourceType\":\"microsoft.operationalinsights/workspaces\",\"visualization\":\"linechart\"},\"name\":\"index-progress\"},{\"type\":3,\"content\":{\"version\":\"KqlItem/1.0\",\"query\":\"ContainerAppConsoleLogs_CL\\n| where ContainerGroupName_s startswith \\\"opcua-pipeline-job\\\"\\n| where Log_s has \\\"Error=\\\" or Log_s has \\\"error\\\" or Log_s has \\\"Warning\\\"\\n| project TimeGenerated, Log_s\\n| order by TimeGenerated desc\\n| take 50\",\"size\":1,\"title\":\"Errors & Warnings\",\"timeContext\":{\"durationMs\":604800000},\"queryType\":0,\"resourceType\":\"microsoft.operationalinsights/workspaces\",\"visualization\":\"table\"},\"name\":\"errors\"},{\"type\":3,\"content\":{\"version\":\"KqlItem/1.0\",\"query\":\"ContainerAppConsoleLogs_CL\\n| where ContainerGroupName_s startswith \\\"opcua-pipeline-job\\\"\\n| where Log_s has \\\"[PIPELINE]\\\" and Log_s has \\\"TotalElapsedSec=\\\"\\n| parse Log_s with * \\\"TotalElapsedSec=\\\" ElapsedSec:long\\n| project TimeGenerated, DurationMin=ElapsedSec/60.0\\n| order by TimeGenerated desc\\n| take 10\",\"size\":1,\"title\":\"Execution History (Duration in Minutes)\",\"timeContext\":{\"durationMs\":2592000000},\"queryType\":0,\"resourceType\":\"microsoft.operationalinsights/workspaces\",\"visualization\":\"barchart\"},\"name\":\"exec-history\"}],\"isLocked\":false}\r\n"
  },
  "resources": {
    "search": {
      "type": "Microsoft.Search/searchServices",
      "apiVersion": "2024-06-01-preview",
      "name": "[variables('searchName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "standard"
      },
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "hostingMode": "default",
        "semanticSearch": "standard",
        "replicaCount": 1,
        "partitionCount": 1
      }
    },
    "foundry": {
      "type": "Microsoft.CognitiveServices/accounts",
      "apiVersion": "2025-04-01-preview",
      "name": "[variables('foundryName')]",
      "location": "[parameters('location')]",
      "kind": "AIServices",
      "identity": {
        "type": "SystemAssigned"
      },
      "sku": {
        "name": "S0"
      },
      "properties": {
        "customSubDomainName": "[variables('foundryName')]",
        "publicNetworkAccess": "Enabled",
        "allowProjectManagement": true,
        "disableLocalAuth": false
      }
    },
    "foundryProject": {
      "type": "Microsoft.CognitiveServices/accounts/projects",
      "apiVersion": "2025-04-01-preview",
      "name": "[format('{0}/{1}', variables('foundryName'), 'default')]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "displayName": "OPC UA Knowledge Base",
        "description": "Foundry project for the OPC UA Knowledge Base (agents, evaluations, models)"
      },
      "dependsOn": [
        "foundry"
      ]
    },
    "gpt4oDeployment": {
      "type": "Microsoft.CognitiveServices/accounts/deployments",
      "apiVersion": "2024-10-01",
      "name": "[format('{0}/{1}', variables('foundryName'), 'gpt-4o')]",
      "sku": {
        "name": "Standard",
        "capacity": 30
      },
      "properties": {
        "model": {
          "format": "OpenAI",
          "name": "gpt-4o",
          "version": "[parameters('gptModelVersion')]"
        }
      },
      "dependsOn": [
        "foundry"
      ]
    },
    "embeddingDeployment": {
      "type": "Microsoft.CognitiveServices/accounts/deployments",
      "apiVersion": "2024-10-01",
      "name": "[format('{0}/{1}', variables('foundryName'), 'text-embedding-3-large')]",
      "sku": {
        "name": "Standard",
        "capacity": 120
      },
      "properties": {
        "model": {
          "format": "OpenAI",
          "name": "text-embedding-3-large",
          "version": "1"
        }
      },
      "dependsOn": [
        "foundry",
        "gpt4oDeployment"
      ]
    },
    "storageAccount": {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-05-01",
      "name": "[variables('storageName')]",
      "location": "[parameters('location')]",
      "kind": "StorageV2",
      "sku": {
        "name": "Standard_LRS"
      },
      "properties": {
        "minimumTlsVersion": "TLS1_2",
        "allowBlobPublicAccess": false,
        "supportsHttpsTrafficOnly": true,
        "allowSharedKeyAccess": false,
        "defaultToOAuthAuthentication": true,
        "publicNetworkAccess": "[if(parameters('lockdownStorage'), 'Disabled', 'Enabled')]",
        "networkAcls": "[if(parameters('lockdownStorage'), createObject('defaultAction', 'Deny', 'bypass', 'AzureServices', 'ipRules', createArray(), 'virtualNetworkRules', createArray()), createObject('defaultAction', 'Allow', 'bypass', 'AzureServices', 'ipRules', createArray(), 'virtualNetworkRules', createArray()))]"
      }
    },
    "vnet": {
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2023-11-01",
      "name": "[variables('vnetName')]",
      "location": "[parameters('location')]",
      "properties": {
        "addressSpace": {
          "addressPrefixes": [
            "[variables('vnetCidr')]"
          ]
        },
        "subnets": [
          {
            "name": "[variables('appsSubnetName')]",
            "properties": {
              "addressPrefix": "[variables('appsSubnetCidr')]",
              "delegations": [
                {
                  "name": "Microsoft.App.environments",
                  "properties": {
                    "serviceName": "Microsoft.App/environments"
                  }
                }
              ]
            }
          },
          {
            "name": "[variables('peSubnetName')]",
            "properties": {
              "addressPrefix": "[variables('peSubnetCidr')]",
              "privateEndpointNetworkPolicies": "Disabled"
            }
          }
        ]
      }
    },
    "appsSubnet": {
      "existing": true,
      "type": "Microsoft.Network/virtualNetworks/subnets",
      "apiVersion": "2023-11-01",
      "name": "[format('{0}/{1}', variables('vnetName'), variables('appsSubnetName'))]",
      "dependsOn": [
        "vnet"
      ]
    },
    "peSubnet": {
      "existing": true,
      "type": "Microsoft.Network/virtualNetworks/subnets",
      "apiVersion": "2023-11-01",
      "name": "[format('{0}/{1}', variables('vnetName'), variables('peSubnetName'))]",
      "dependsOn": [
        "vnet"
      ]
    },
    "blobPrivateDnsZone": {
      "type": "Microsoft.Network/privateDnsZones",
      "apiVersion": "2020-06-01",
      "name": "privatelink.blob.core.windows.net",
      "location": "global"
    },
    "blobPrivateDnsZoneLink": {
      "type": "Microsoft.Network/privateDnsZones/virtualNetworkLinks",
      "apiVersion": "2020-06-01",
      "name": "[format('{0}/{1}', 'privatelink.blob.core.windows.net', format('{0}-link', variables('vnetName')))]",
      "location": "global",
      "properties": {
        "registrationEnabled": false,
        "virtualNetwork": {
          "id": "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]"
        }
      },
      "dependsOn": [
        "blobPrivateDnsZone",
        "vnet"
      ]
    },
    "storagePrivateEndpoint": {
      "type": "Microsoft.Network/privateEndpoints",
      "apiVersion": "2023-11-01",
      "name": "[format('{0}-storage-pe', parameters('prefix'))]",
      "location": "[parameters('location')]",
      "properties": {
        "subnet": {
          "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets', variables('vnetName'), variables('peSubnetName'))]"
        },
        "privateLinkServiceConnections": [
          {
            "name": "blob",
            "properties": {
              "privateLinkServiceId": "[resourceId('Microsoft.Storage/storageAccounts', variables('storageName'))]",
              "groupIds": [
                "blob"
              ]
            }
          }
        ]
      },
      "dependsOn": [
        "storageAccount",
        "vnet"
      ]
    },
    "storagePrivateEndpointDnsGroup": {
      "type": "Microsoft.Network/privateEndpoints/privateDnsZoneGroups",
      "apiVersion": "2023-11-01",
      "name": "[format('{0}/{1}', format('{0}-storage-pe', parameters('prefix')), 'blob-dns-zone-group')]",
      "properties": {
        "privateDnsZoneConfigs": [
          {
            "name": "blob",
            "properties": {
              "privateDnsZoneId": "[resourceId('Microsoft.Network/privateDnsZones', 'privatelink.blob.core.windows.net')]"
            }
          }
        ]
      },
      "dependsOn": [
        "blobPrivateDnsZone",
        "storagePrivateEndpoint"
      ]
    },
    "docai": {
      "type": "Microsoft.CognitiveServices/accounts",
      "apiVersion": "2024-10-01",
      "name": "[variables('docaiName')]",
      "location": "[parameters('location')]",
      "kind": "FormRecognizer",
      "sku": {
        "name": "S0"
      },
      "properties": {
        "customSubDomainName": "[variables('docaiName')]",
        "publicNetworkAccess": "Enabled"
      }
    },
    "acr": {
      "type": "Microsoft.ContainerRegistry/registries",
      "apiVersion": "2023-11-01-preview",
      "name": "[variables('acrName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Basic"
      },
      "properties": {
        "adminUserEnabled": false
      }
    },
    "logAnalytics": {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2023-09-01",
      "name": "[variables('logAnalyticsName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 30
      }
    },
    "containerEnv": {
      "type": "Microsoft.App/managedEnvironments",
      "apiVersion": "2024-03-01",
      "name": "[variables('envName')]",
      "location": "[parameters('location')]",
      "properties": {
        "appLogsConfiguration": {
          "destination": "log-analytics",
          "logAnalyticsConfiguration": {
            "customerId": "[reference('logAnalytics').customerId]",
            "sharedKey": "[listKeys('logAnalytics', '2023-09-01').primarySharedKey]"
          }
        },
        "workloadProfiles": [
          {
            "name": "Consumption",
            "workloadProfileType": "Consumption"
          }
        ],
        "vnetConfiguration": {
          "infrastructureSubnetId": "[resourceId('Microsoft.Network/virtualNetworks/subnets', variables('vnetName'), variables('appsSubnetName'))]",
          "internal": false
        }
      },
      "dependsOn": [
        "logAnalytics",
        "vnet"
      ]
    },
    "pipelineJob": {
      "type": "Microsoft.App/jobs",
      "apiVersion": "2024-03-01",
      "name": "[variables('jobName')]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "environmentId": "[resourceId('Microsoft.App/managedEnvironments', variables('envName'))]",
        "workloadProfileName": "Consumption",
        "configuration": {
          "triggerType": "Schedule",
          "scheduleTriggerConfig": {
            "cronExpression": "[parameters('cronSchedule')]",
            "parallelism": 1,
            "replicaCompletionCount": 1
          },
          "replicaTimeout": 86400,
          "registries": [
            {
              "server": "[reference('acr').loginServer]",
              "identity": "system"
            }
          ],
          "secrets": "[concat(createArray(createObject('name', 'search-api-key', 'value', listAdminKeys('search', '2024-06-01-preview').primaryKey)), if(empty(parameters('cloudLibUsername')), createArray(), createArray(createObject('name', 'cloudlib-username', 'value', parameters('cloudLibUsername')), createObject('name', 'cloudlib-password', 'value', parameters('cloudLibPassword')))))]"
        },
        "template": {
          "containers": [
            {
              "name": "pipeline",
              "image": "[variables('containerImage')]",
              "resources": {
                "cpu": "[json('2')]",
                "memory": "4Gi"
              },
              "env": "[concat(createArray(createObject('name', 'STORAGE_ACCOUNT_NAME', 'value', variables('storageName')), createObject('name', 'SEARCH_ENDPOINT', 'value', format('https://{0}.search.windows.net', variables('searchName'))), createObject('name', 'SEARCH_API_KEY', 'secretRef', 'search-api-key'), createObject('name', 'AOAI_ENDPOINT', 'value', reference('foundry').endpoint)), if(empty(parameters('cloudLibUsername')), createArray(), createArray(createObject('name', 'CLOUDLIB_USERNAME', 'secretRef', 'cloudlib-username'), createObject('name', 'CLOUDLIB_PASSWORD', 'secretRef', 'cloudlib-password'))))]"
            }
          ]
        }
      },
      "dependsOn": [
        "acr",
        "containerEnv",
        "foundry",
        "search",
        "storageAccount"
      ]
    },
    "mcpServer": {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2024-03-01",
      "name": "[variables('mcpAppName')]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "environmentId": "[resourceId('Microsoft.App/managedEnvironments', variables('envName'))]",
        "workloadProfileName": "Consumption",
        "configuration": {
          "activeRevisionsMode": "Single",
          "ingress": {
            "external": true,
            "targetPort": 8080,
            "transport": "http",
            "allowInsecure": false
          },
          "registries": [
            {
              "server": "[reference('acr').loginServer]",
              "identity": "system"
            }
          ],
          "secrets": [
            {
              "name": "search-api-key",
              "value": "[listAdminKeys('search', '2024-06-01-preview').primaryKey]"
            }
          ]
        },
        "template": {
          "containers": [
            {
              "name": "mcp-server",
              "image": "[if(empty(parameters('pipelineImage')), 'mcr.microsoft.com/dotnet/aspnet:10.0', format('{0}/opcua-mcp-server:latest', reference('acr').loginServer))]",
              "resources": {
                "cpu": "[json('1.0')]",
                "memory": "2Gi"
              },
              "env": [
                {
                  "name": "SEARCH_ENDPOINT",
                  "value": "[format('https://{0}.search.windows.net', variables('searchName'))]"
                },
                {
                  "name": "SEARCH_API_KEY",
                  "secretRef": "search-api-key"
                },
                {
                  "name": "AOAI_ENDPOINT",
                  "value": "[reference('foundry').endpoint]"
                },
                {
                  "name": "STORAGE_ACCOUNT_NAME",
                  "value": "[variables('storageName')]"
                },
                {
                  "name": "MCP_API_KEY",
                  "secretRef": "search-api-key"
                },
                {
                  "name": "MCP_REQUIRE_AUTH",
                  "value": "false"
                },
                {
                  "name": "MCP_ANON_RATE_LIMIT",
                  "value": "100"
                }
              ]
            }
          ],
          "scale": {
            "minReplicas": 0,
            "maxReplicas": 2,
            "rules": [
              {
                "name": "http-rule",
                "http": {
                  "metadata": {
                    "concurrentRequests": "5"
                  }
                }
              }
            ]
          }
        }
      },
      "dependsOn": [
        "acr",
        "containerEnv",
        "foundry",
        "search",
        "storageAccount",
        "storagePrivateEndpointDnsGroup"
      ]
    },
    "searchFoundryRoleAssignment": {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[format('Microsoft.CognitiveServices/accounts/{0}', variables('foundryName'))]",
      "name": "[guid(resourceId('Microsoft.Search/searchServices', variables('searchName')), resourceId('Microsoft.CognitiveServices/accounts', variables('foundryName')), variables('cognitiveServicesOpenAIUserRole'))]",
      "properties": {
        "principalId": "[reference('search', '2024-06-01-preview', 'full').identity.principalId]",
        "principalType": "ServicePrincipal",
        "roleDefinitionId": "[variables('cognitiveServicesOpenAIUserRole')]"
      },
      "dependsOn": [
        "foundry",
        "search"
      ]
    },
    "pipelineJobFoundryRoleAssignment": {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[format('Microsoft.CognitiveServices/accounts/{0}', variables('foundryName'))]",
      "name": "[guid(resourceId('Microsoft.App/jobs', variables('jobName')), resourceId('Microsoft.CognitiveServices/accounts', variables('foundryName')), variables('cognitiveServicesOpenAIUserRole'))]",
      "properties": {
        "principalId": "[reference('pipelineJob', '2024-03-01', 'full').identity.principalId]",
        "principalType": "ServicePrincipal",
        "roleDefinitionId": "[variables('cognitiveServicesOpenAIUserRole')]"
      },
      "dependsOn": [
        "foundry",
        "pipelineJob"
      ]
    },
    "mcpServerFoundryRoleAssignment": {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[format('Microsoft.CognitiveServices/accounts/{0}', variables('foundryName'))]",
      "name": "[guid(resourceId('Microsoft.App/containerApps', variables('mcpAppName')), resourceId('Microsoft.CognitiveServices/accounts', variables('foundryName')), variables('cognitiveServicesOpenAIUserRole'))]",
      "properties": {
        "principalId": "[reference('mcpServer', '2024-03-01', 'full').identity.principalId]",
        "principalType": "ServicePrincipal",
        "roleDefinitionId": "[variables('cognitiveServicesOpenAIUserRole')]"
      },
      "dependsOn": [
        "foundry",
        "mcpServer"
      ]
    },
    "pipelineJobStorageBlobContributor": {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[format('Microsoft.Storage/storageAccounts/{0}', variables('storageName'))]",
      "name": "[guid(resourceId('Microsoft.App/jobs', variables('jobName')), resourceId('Microsoft.Storage/storageAccounts', variables('storageName')), 'StorageBlobDataContributor')]",
      "properties": {
        "principalId": "[reference('pipelineJob', '2024-03-01', 'full').identity.principalId]",
        "principalType": "ServicePrincipal",
        "roleDefinitionId": "[variables('storageBlobDataContributorRole')]"
      },
      "dependsOn": [
        "pipelineJob",
        "storageAccount"
      ]
    },
    "mcpServerStorageBlobContributor": {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[format('Microsoft.Storage/storageAccounts/{0}', variables('storageName'))]",
      "name": "[guid(resourceId('Microsoft.App/containerApps', variables('mcpAppName')), resourceId('Microsoft.Storage/storageAccounts', variables('storageName')), 'StorageBlobDataContributor')]",
      "properties": {
        "principalId": "[reference('mcpServer', '2024-03-01', 'full').identity.principalId]",
        "principalType": "ServicePrincipal",
        "roleDefinitionId": "[variables('storageBlobDataContributorRole')]"
      },
      "dependsOn": [
        "mcpServer",
        "storageAccount"
      ]
    },
    "pipelineJobAcrPull": {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[format('Microsoft.ContainerRegistry/registries/{0}', variables('acrName'))]",
      "name": "[guid(resourceId('Microsoft.App/jobs', variables('jobName')), resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), 'AcrPull')]",
      "properties": {
        "principalId": "[reference('pipelineJob', '2024-03-01', 'full').identity.principalId]",
        "principalType": "ServicePrincipal",
        "roleDefinitionId": "[variables('acrPullRole')]"
      },
      "dependsOn": [
        "acr",
        "pipelineJob"
      ]
    },
    "mcpServerAcrPull": {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[format('Microsoft.ContainerRegistry/registries/{0}', variables('acrName'))]",
      "name": "[guid(resourceId('Microsoft.App/containerApps', variables('mcpAppName')), resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), 'AcrPull')]",
      "properties": {
        "principalId": "[reference('mcpServer', '2024-03-01', 'full').identity.principalId]",
        "principalType": "ServicePrincipal",
        "roleDefinitionId": "[variables('acrPullRole')]"
      },
      "dependsOn": [
        "acr",
        "mcpServer"
      ]
    },
    "storageLifecyclePolicy": {
      "type": "Microsoft.Storage/storageAccounts/managementPolicies",
      "apiVersion": "2023-05-01",
      "name": "[format('{0}/{1}', variables('storageName'), 'default')]",
      "properties": {
        "policy": {
          "rules": [
            {
              "name": "expire-uploaded-nodesets",
              "enabled": true,
              "type": "Lifecycle",
              "definition": {
                "filters": {
                  "blobTypes": [
                    "blockBlob"
                  ],
                  "prefixMatch": [
                    "opcua-content/uploads/"
                  ]
                },
                "actions": {
                  "baseBlob": {
                    "delete": {
                      "daysAfterCreationGreaterThan": 1
                    }
                  }
                }
              }
            }
          ]
        }
      },
      "dependsOn": [
        "storageAccount"
      ]
    },
    "workbook": {
      "type": "Microsoft.Insights/workbooks",
      "apiVersion": "2022-04-01",
      "name": "[variables('workbookName')]",
      "location": "[parameters('location')]",
      "kind": "shared",
      "properties": {
        "displayName": "OPC UA Pipeline Dashboard",
        "category": "workbook",
        "sourceId": "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName'))]",
        "serializedData": "[variables('workbookContent')]"
      },
      "dependsOn": [
        "logAnalytics"
      ]
    }
  },
  "outputs": {
    "searchEndpoint": {
      "type": "string",
      "value": "[format('https://{0}.search.windows.net', variables('searchName'))]"
    },
    "searchApiKey": {
      "type": "securestring",
      "value": "[listAdminKeys('search', '2024-06-01-preview').primaryKey]"
    },
    "foundryEndpoint": {
      "type": "string",
      "value": "[reference('foundry').endpoint]"
    },
    "foundryProjectEndpoint": {
      "type": "string",
      "value": "[format('https://{0}.services.ai.azure.com/api/projects/{1}', variables('foundryName'), 'default')]"
    },
    "aoaiEndpoint": {
      "type": "string",
      "value": "[reference('foundry').endpoint]"
    },
    "storageAccountName": {
      "type": "string",
      "value": "[variables('storageName')]"
    },
    "acrLoginServer": {
      "type": "string",
      "value": "[reference('acr').loginServer]"
    },
    "mcpEndpoint": {
      "type": "string",
      "value": "[format('https://{0}.search.windows.net/knowledgebases/{1}-kb/mcp?api-version=2025-11-01-preview', variables('searchName'), parameters('prefix'))]"
    },
    "mcpServerEndpoint": {
      "type": "string",
      "value": "[format('https://{0}', reference('mcpServer').configuration.ingress.fqdn)]"
    },
    "vnetId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]"
    },
    "storagePrivateEndpointId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Network/privateEndpoints', format('{0}-storage-pe', parameters('prefix')))]"
    }
  }
}