# OPC UA KB Agent — Bot Framework / Microsoft 365 Agents SDK custom engine agent
# Hosted as a stateless web app on Azure Container Apps.

FROM mcr.microsoft.com/dotnet/sdk:10.0-preview AS build
WORKDIR /src

# Copy the projects we need (Core + Agent)
COPY src/OpcUaKb.Core/ ./OpcUaKb.Core/
COPY src/OpcUaKb.Agent/ ./OpcUaKb.Agent/

WORKDIR /src/OpcUaKb.Agent
RUN dotnet restore
RUN dotnet publish -c Release -o /app --no-restore

FROM mcr.microsoft.com/dotnet/aspnet:10.0-preview
WORKDIR /app
COPY --from=build /app .

# Bot Framework messaging endpoint listens on port 8080 (Container Apps default ingress)
EXPOSE 8080
ENV ASPNETCORE_URLS=http://+:8080

ENTRYPOINT ["dotnet", "OpcUaKb.Agent.dll"]
